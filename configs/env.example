# AIStack Environment Configuration
# Copy to .env and customize before running aistack up
# Generated by: aistack install

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Change this to a random secret (generated automatically on install)
WEBUI_SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY_32CHARS

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_NAME=AIStack
WEBUI_AUTH=True
ENABLE_SIGNUP=True
# Options: user | admin | pending
DEFAULT_USER_ROLE=user
ENABLE_COMMUNITY_SHARING=False
WEBUI_ENV=prod

# ── Ports ─────────────────────────────────────────────────────────────────────
# Open WebUI: bind to all interfaces by default
WEBUI_HOST=0.0.0.0
WEBUI_PORT=3000

# Ollama: bind to localhost only by default (accessed via internal network)
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# ── Ollama Settings ───────────────────────────────────────────────────────────
OLLAMA_ORIGINS=*
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_FLASH_ATTENTION=1

# KV Cache quantization (reduces VRAM): q8_0 | q4_0 | f16
OLLAMA_KV_CACHE_TYPE=q8_0

# CPU threads (0 = auto)
OLLAMA_NUM_THREADS=0

# ── GPU Settings (NVIDIA) ─────────────────────────────────────────────────────
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_GPU_COUNT=all
# Fraction of GPU VRAM to use (0.0-1.0)
OLLAMA_GPU_MEMORY_FRACTION=0.9

# ── Profile ───────────────────────────────────────────────────────────────────
# Set by aistack install automatically. Options: cpu | nvidia-8gb | nvidia-16gb | nvidia-24gb
AISTACK_PROFILE=cpu

# ── Resource Limits ───────────────────────────────────────────────────────────
# Max RAM for Ollama in CPU mode
CPU_MEMORY_LIMIT=16G

# ── Monitoring (optional) ─────────────────────────────────────────────────────
GRAFANA_PASSWORD=aistack

# ── Installation Metadata ─────────────────────────────────────────────────────
# Set automatically by installer
AISTACK_VERSION=
AISTACK_INSTALLED_AT=
AISTACK_HOST_HOSTNAME=
